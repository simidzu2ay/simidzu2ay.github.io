{
	"name": "simidzu2ay.github.io",
	"author": "Simidzu Ay",
	"version": "1.0.0",
	"scripts": {
		"dev": "svelte-kit dev",
		"build": "rm -rf build && svelte-kit build && touch ./build/.nojekyll",
		"package": "svelte-kit package",
		"preview": "svelte-kit preview",
		"prepare": "svelte-kit sync",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier -w **/*.{js,ts,svelte,css,html}",
		"gh:publish": "npm run build && node ./scripts/publish.js"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "next",
		"@sveltejs/kit": "next",
		"autoprefixer": "^10.4.7",
		"gh-pages": "^4.0.0",
		"postcss": "^8.4.13",
		"prettier": "^2.5.1",
		"prettier-plugin-svelte": "^2.5.0",
		"prettier-plugin-tailwindcss": "^0.1.10",
		"svelte": "^3.44.0",
		"svelte-check": "^2.2.6",
		"svelte-preprocess": "^4.10.1",
		"tailwindcss": "^3.0.24",
		"tslib": "^2.3.1",
		"typescript": "~4.6.2"
	},
	"type": "module",
	"dependencies": {
		"@sveltejs/adapter-static": "1.0.0-next.30"
	}
}
